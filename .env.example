# DionAi — AWS account aliases
#
# Each AWS account you want to investigate gets 3 entries:
#   <alias>_PROFILE  (local AWS profile name, from ~/.aws/credentials)
#   <alias>_STAGE    (default stage, e.g. prod, staging, dev)
#   <alias>_REGION   (default AWS region, e.g. eu-west-1, us-east-1)
#
# The alias is the name you type when asking for an investigation.
# Example: "investigate gbInnovations why the job failed at 3pm"
#
# Copy this file to .env and fill in the real values. .env is gitignored.

gbInnovations_PROFILE=
gbInnovations_STAGE=
gbInnovations_REGION=

equality_PROFILE=
equality_STAGE=
equality_REGION=
